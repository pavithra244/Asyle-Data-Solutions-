<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manage Users | Asyle Admin</title>
    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <!-- Admin Dashboard CSS -->
    <link rel="stylesheet" href="/css/admin-dashboard.css">
</head>

<body>

    <aside class="sidebar">
        <div class="logo">
            <i class="fas fa-shield-alt"></i>
            <span>Asyle Admin</span>
        </div>
        <nav class="nav-links">
            <a href="/admin/dashboard" class="nav-link">
                <i class="fas fa-home"></i> Dashboard
            </a>
            <a href="/admin/users" class="nav-link active">
                <i class="fas fa-users"></i> Users
            </a>
            <a href="/admin/publications" class="nav-link">
                <i class="fas fa-file-alt"></i> Publications
            </a>
            <a href="/admin/chat" class="nav-link">
                <i class="fas fa-comments"></i> Chat Support
            </a>
            <a href="/logout" class="nav-link logout-link">
                <i class="fas fa-sign-out-alt"></i> Logout
            </a>
        </nav>
    </aside>
    <div class="overlay" onclick="toggleSidebar()"></div>

    <main class="main-wrapper">
        <header class="top-navbar">
            <button class="menu-toggle" onclick="toggleSidebar()">
                <i class="fas fa-bars"></i>
            </button>
            <div>
                <h2 style="font-weight: 800;">User Management</h2>
                <p style="color: var(--text-muted); font-size: 0.9rem;">Manage system users and access levels</p>
            </div>
            <% if (typeof admin !=='undefined' ) { %>
                <div class="admin-profile">
                    <div class="admin-info" style="text-align: right;">
                        <p style="font-weight: 700; font-size: 0.9rem;">
                            <%= admin.username %>
                        </p>
                        <p style="font-size: 0.75rem; color: var(--text-muted);">Super Admin</p>
                    </div>
                    <div class="avatar">
                        <%= admin.username.charAt(0).toUpperCase() %>
                    </div>
                </div>
                <% } %>
        </header>

        <div class="table-card">
            <div class="table-header">
                <h3 style="font-weight: 700;">All Registered Users</h3>
                <span
                    style="background: var(--primary-glow); color: var(--primary); padding: 4px 12px; border-radius: 100px; font-size: 0.8rem; font-weight: 700;">
                    <%= users.length %> Total
                </span>
            </div>
            <div class="table-container">
                <table>
                    <thead>
                        <tr>
                            <th>User</th>
                            <th>Email</th>
                            <th>Status</th>
                            <th>Role</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% users.forEach(user=> { %>
                            <tr>
                                <td>
                                    <div class="user-cell">
                                        <div class="avatar"
                                            style="width: 32px; height: 32px; font-size: 0.8rem; border-radius: 8px;">
                                            <%= user.username.charAt(0).toUpperCase() %>
                                        </div>
                                        <span style="font-weight: 600;">
                                            <%= user.username %>
                                        </span>
                                    </div>
                                </td>
                                <td style="color: var(--text-muted); font-size: 0.9rem;">
                                    <%= user.email %>
                                </td>
                                <td>
                                    <% if (user.status==='pending' ) { %>
                                        <span class="status-badge badge-pending"><i class="fas fa-circle-dot"></i>
                                            Pending</span>
                                        <% } else if (user.status==='approved' ) { %>
                                            <span class="status-badge badge-approved"><i
                                                    class="fas fa-check-circle"></i> Approved</span>
                                            <% } else { %>
                                                <span class="status-badge badge-denied"><i
                                                        class="fas fa-times-circle"></i> Denied</span>
                                                <% } %>
                                </td>
                                <td>
                                    <span
                                        class="role-pill <%= user.role === 'admin' ? 'role-admin' : 'role-customer' %>">
                                        <%= user.role.charAt(0).toUpperCase() + user.role.slice(1) %>
                                    </span>
                                </td>
                                <td>
                                    <div style="display: flex; gap: 8px;">
                                        <% if (user.role !=='admin' ) { %>
                                            <% if (user.status==='pending' ) { %>
                                                <form method="POST" action="/admin/users/approve/<%= user.id %>"
                                                    style="margin: 0;">
                                                    <button type="submit" class="btn-action" title="Approve"
                                                        style="color: var(--success); border-color: var(--success); background: #ecfdf5; width: 32px; height: 32px;">
                                                        <i class="fas fa-check" style="font-size: 0.8rem;"></i>
                                                    </button>
                                                </form>
                                                <form method="POST" action="/admin/users/deny/<%= user.id %>"
                                                    style="margin: 0;">
                                                    <button type="submit" class="btn-action" title="Deny"
                                                        style="color: var(--danger); border-color: var(--danger); background: #fef2f2; width: 32px; height: 32px;">
                                                        <i class="fas fa-times" style="font-size: 0.8rem;"></i>
                                                    </button>
                                                </form>
                                                <% } else if (user.status==='approved' ) { %>
                                                    <form method="POST" action="/admin/users/deny/<%= user.id %>"
                                                        style="margin: 0;"
                                                        onsubmit="return confirm('Block <%= user.username %>?')">
                                                        <button type="submit" class="btn-action" title="Block User"
                                                            style="color: var(--danger);">
                                                            <i class="fas fa-ban"></i>
                                                        </button>
                                                    </form>
                                                    <% } else if (user.status==='denied' ) { %>
                                                        <form method="POST" action="/admin/users/approve/<%= user.id %>"
                                                            style="margin: 0;"
                                                            onsubmit="return confirm('Unblock <%= user.username %>?')">
                                                            <button type="submit" class="btn-action"
                                                                title="Unblock User" style="color: var(--success);">
                                                                <i class="fas fa-unlock"></i>
                                                            </button>
                                                        </form>
                                                        <% } %>
                                                            <form action="/admin/users/delete/<%= user.id %>"
                                                                method="POST"
                                                                style="display:inline-block; margin-left: 5px;"
                                                                onsubmit="return confirm('Are you sure you want to delete this user? This action cannot be undone.');">
                                                                <button type="submit" class="action-btn delete"
                                                                    title="Delete User"
                                                                    style="color: var(--danger); border-color: var(--danger); background: #fef2f2; width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; border-radius: 8px; border: 1px solid;">
                                                                    <i class="fas fa-trash-alt"
                                                                        style="font-size: 0.8rem;"></i>
                                                                </button>
                                                            </form>
                                                            <% } else { %>
                                                                <span
                                                                    style="font-size: 0.8rem; color: var(--text-muted); font-style: italic;">Admin</span>
                                                                <% } %>
                                    </div>
                                </td>
                            </tr>
                            <% }) %>
                                <% if (users.length===0) { %>
                                    <tr>
                                        <td colspan="5"
                                            style="text-align: center; padding: 40px; color: var(--text-muted);">
                                            No users found.
                                        </td>
                                    </tr>
                                    <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </main>

    <script>
        function toggleSidebar() {
            const sidebar = document.querySelector('.sidebar');
            const overlay = document.querySelector('.overlay');
            sidebar.classList.toggle('mobile-open');
            overlay.classList.toggle('active');
        }
    </script>
</body>

</html>
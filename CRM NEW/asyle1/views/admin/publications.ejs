<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manage Publications | Asyle Admin</title>
    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="/css/admin-dashboard.css">
</head>

<body>
    <aside class="sidebar" id="sidebar">
        <div class="logo">
            <i class="fas fa-shield-alt"></i>
            <span>Asyle Admin</span>
        </div>
        <nav class="nav-links">
            <a href="/admin/dashboard" class="nav-link">
                <i class="fas fa-home"></i> Dashboard
            </a>
            <a href="/admin/users" class="nav-link">
                <i class="fas fa-users"></i> Users
            </a>
            <a href="/admin/publications" class="nav-link active">
                <i class="fas fa-file-alt"></i> Publications
            </a>
            <a href="/admin/chat" class="nav-link">
                <i class="fas fa-comments"></i> Chat Support
            </a>
            <a href="/logout" class="nav-link logout-link">
                <i class="fas fa-sign-out-alt"></i> Logout
            </a>
        </nav>
    </aside>
    <div class="overlay" onclick="toggleSidebar()"></div>

    <main class="main-wrapper">
        <header class="top-navbar">
            <button class="menu-toggle" onclick="toggleSidebar()">
                <i class="fas fa-bars"></i>
            </button>
            <div>
                <h2 style="font-weight: 800; font-size: 1.8rem; margin-bottom: 4px;">Publications</h2>
                <p style="color: var(--text-muted);">Manage research documents and access levels</p>
            </div>
            <!-- Mobile Toggle -->
        </header>

        <!-- Upload Form -->
        <section class="card">
            <div class="card-header">
                <i class="fas fa-cloud-upload-alt"></i>
                <h2>Upload New Publication</h2>
            </div>
            <form action="/admin/publications/upload" method="POST" enctype="multipart/form-data">
                <div class="form-group">
                    <label class="form-label">Publication Title</label>
                    <input type="text" name="title" class="form-control" required
                        placeholder="e.g., Q1 Research Report">
                </div>
                <div class="form-group">
                    <label class="form-label">Description</label>
                    <textarea name="description" class="form-control" rows="3"
                        placeholder="Brief summary of the document..."></textarea>
                </div>

                <div class="form-group">
                    <label class="form-label">Document File</label>
                    <div class="file-upload-wrapper">
                        <i class="fas fa-file-import fa-2x" style="color: var(--primary); margin-bottom: 12px;"></i>
                        <p style="font-weight: 600; margin-bottom: 4px;">Click to browse or drag file here</p>
                        <p style="font-size: 0.8rem; color: var(--text-muted);">Supports PDF, DOCX, TXT (Max 10MB)</p>
                        <input type="file" name="file" required
                            onchange="this.previousElementSibling.previousElementSibling.textContent = this.files[0].name">
                    </div>
                </div>

                <div class="form-group">
                    <label class="checkbox-wrapper">
                        <input type="checkbox" name="is_downloadable" value="1">
                        <span style="font-weight: 500;">Allow public download</span>
                    </label>
                </div>

                <button type="submit" class="btn-primary">
                    <i class="fas fa-upload"></i> Upload Publication
                </button>
            </form>
        </section>

        <!-- Publications Table -->
        <section class="card" style="padding: 0; overflow: hidden;">
            <div
                style="padding: 24px 32px; border-bottom: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center;">
                <h3 style="font-weight: 700; font-size: 1.1rem;"><i class="fas fa-list me-2"></i> Existing Publications
                </h3>
                <span
                    style="background: var(--primary-glow); color: var(--primary); padding: 4px 12px; border-radius: 100px; font-size: 0.8rem; font-weight: 700;">
                    <%= publications.length %> Total
                </span>
            </div>

            <div class="table-container">
                <table>
                    <thead>
                        <tr>
                            <th>Document Title</th>
                            <th>Type</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% publications.forEach(pub=> { %>
                            <tr>
                                <td>
                                    <div style="font-weight: 600; color: var(--text-main);">
                                        <%= pub.title %>
                                    </div>
                                    <div
                                        style="font-size: 0.8rem; color: var(--text-muted); max-width: 300px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                        <%= pub.description || 'No description' %>
                                    </div>
                                </td>
                                <td>
                                    <% let typeClass=pub.file_type==='PDF' ? 'type-pdf' : 'type-doc' ; %>
                                        <span class="type-badge <%= typeClass %>">
                                            <%= pub.file_type %>
                                        </span>
                                </td>
                                <td>
                                    <% if (pub.is_downloadable) { %>
                                        <span class="status-pill status-public"><i class="fas fa-check-circle"></i>
                                            Public</span>
                                        <% } else { %>
                                            <span class="status-pill status-restricted"><i class="fas fa-lock"></i>
                                                Restricted</span>
                                            <% } %>
                                </td>
                                <td>
                                    <a href="<%= pub.file_path %>" target="_blank" class="action-btn" title="View">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a href="/admin/permissions/<%= pub.id %>" class="action-btn"
                                        title="Manage Permissions">
                                        <i class="fas fa-key"></i>
                                    </a>
                                    <a href="/admin/publications/delete/<%= pub.id %>" class="action-btn delete"
                                        onclick="return confirm('Delete this publication?')" title="Delete">
                                        <i class="fas fa-trash-alt"></i>
                                    </a>
                                </td>
                            </tr>
                            <% }) %>

                                <% if (publications.length===0) { %>
                                    <tr>
                                        <td colspan="4" style="text-align: center; padding: 40px;">
                                            <div style="opacity: 0.5;">
                                                <i class="fas fa-folder-open fa-3x mb-3"></i>
                                                <p>No publications found.</p>
                                            </div>
                                        </td>
                                    </tr>
                                    <% } %>
                    </tbody>
                </table>
            </div>
        </section>
    </main>

    <script>
        function toggleSidebar() {
            const sidebar = document.querySelector('.sidebar');
            const overlay = document.querySelector('.overlay');
            sidebar.classList.toggle('mobile-open');
            overlay.classList.toggle('active');
        }
    </script>
</body>

</html>
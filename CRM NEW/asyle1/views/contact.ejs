<%- include('partials/header') %>

  <div class="page-header parallaxie"
    style="background-image: url('images/CWB-banner-3.png'); background-size: cover; background-position: center; background-attachment: fixed;">
    <div class="container">
      <div class="row align-items-center">
        <div class="col-lg-12">
          <div class="page-header-box">
            <h1 class="wow fadeInUp" data-cursor="-opaque">Contact Us</h1>
            <nav class="wow fadeInUp" data-wow-delay="0.2s">
              <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="./">home</a></li>
                <li class="breadcrumb-item active" aria-current="page">Contact Us</li>
              </ol>
            </nav>
          </div>
        </div>
      </div>
    </div>
  </div>

  <section class="modern-contact-section py-5">
    <div class="modern-container">

      <div class="contact-left">
        <p class="subtitle">CONTACT US</p>
        <h2 class="title">We’re Here to Help You</h2>
        <p class="description">
          Have questions, suggestions, or project requests? Fill out the form below and our team will get back to you
          promptly.
        </p>

        <div class="contact-cards">
          <div class="card">
            <div class="icon-circle">
              <img src="https://img.icons8.com/ios-filled/50/ffffff/marker.png" alt="Location">
            </div>
            <div class="info">
              <strong>Near By Sridevi Silks</strong>
              <span>6th Street, Gandhipuram-641012</span>
            </div>
          </div>

          <div class="card">
            <div class="icon-circle">
              <img src="https://img.icons8.com/ios-filled/50/ffffff/phone.png" alt="Phone">
            </div>
            <div class="info">
              <strong>+91 95243 35179</strong>
              <span>Mon-Sat, 9AM - 6PM</span>
            </div>
          </div>

          <div class="card">
            <div class="icon-circle">
              <img src="https://img.icons8.com/ios-filled/50/ffffff/new-post.png" alt="Email">
            </div>
            <div class="info">
              <strong>asyledatasolutions@gmail.com</strong>
              <span>Email us anytime</span>
            </div>
          </div>
        </div>

        <h3 class="form-title">Send a Message</h3>
        <% if (locals.success) { %>
          <div class="alert alert-success">Message sent successfully!</div>
          <% } %>
            <form action="/send-email" method="POST">
              <div class="form-row">
                <input type="text" name="name" placeholder="Your Name" required>
                <input type="email" name="email" placeholder="Email Address" required>
              </div>
              <div class="form-row">
                <input type="tel" name="phone" placeholder="Phone Number">
                <input type="text" name="subject" placeholder="Subject">
              </div>
              <textarea name="message" rows="6" placeholder="Your Message" required></textarea>
              <button type="submit">Send Message</button>
            </form>
      </div>

      <div class="contact-right">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3916.4674560836326!2d76.9666502!3d11.0182523!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3ba85855cbcdc163%3A0xde0921548e594c4b!2sAsyle%20Data%20Solutions!5e0!3m2!1sen!2sin!4v1706089999999"
          loading="lazy" referrerpolicy="no-referrer-when-downgrade">
        </iframe>
      </div>

    </div>
  </section>

  <style>
    .modern-container {
      display: flex;
      flex-wrap: wrap;
      max-width: 1200px;
      margin: 0 auto;
      padding: 50px 20px;
      gap: 40px;
    }

    .contact-left {
      flex: 1 1 500px;
    }

    .subtitle {
      color: #f67119;
      font-weight: 600;
      letter-spacing: 1px;
      text-transform: uppercase;
      margin-bottom: 10px;
    }

    .title {
      font-size: 2.5rem;
      margin-bottom: 20px;
      line-height: 1.3;
    }

    .description {
      font-size: 1rem;
      margin-bottom: 30px;
      color: #555;
      line-height: 1.6;
    }

    .contact-cards {
      display: flex;
      flex-wrap: wrap;
      gap: 20px;
      margin-bottom: 40px;
    }

    .card {
      display: flex;
      align-items: center;
      background: linear-gradient(135deg, #ffffff, #ffffff);
      padding: 20px;
      border-radius: 15px;
      box-shadow: 0 15px 35px rgba(0, 0, 0, 0.1);
      flex: 1 1 200px;
      gap: 15px;
      transition: transform 0.3s, box-shadow 0.3s;
    }

    .card:hover {
      transform: translateY(-5px);
      box-shadow: 0 25px 45px rgba(0, 0, 0, 0.15);
    }

    .icon-circle {
      width: 60px;
      height: 60px;
      background: linear-gradient(135deg, #4234d8, #4234d8);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
      transition: transform 0.3s, box-shadow 0.3s;
    }

    .icon-circle img {
      width: 30px;
      height: 30px;
    }

    .card:hover .icon-circle {
      transform: translateY(-5px);
      box-shadow: 0 15px 25px rgba(0, 0, 0, 0.2);
    }

    .card .info strong {
      display: block;
      font-size: 1.1rem;
      color: #333;
      margin-bottom: 5px;
    }

    .card .info span {
      color: #666;
      font-size: 0.9rem;
    }

    .form-title {
      font-size: 1.5rem;
      margin-bottom: 15px;
      color: #333;
    }

    form {
      display: flex;
      flex-direction: column;
      gap: 15px;
    }

    .form-row {
      display: flex;
      gap: 15px;
      flex-wrap: wrap;
    }

    input,
    textarea {
      width: 100%;
      padding: 14px;
      border: 1px solid #000000;
      font-size: 1rem;
      transition: 0.3s;
    }

    input:focus,
    textarea:focus {
      border-color: #000000;
      box-shadow: 0 0 8px rgba(60, 180, 110, 0.2);
      outline: none;
    }

    button {
      background-color: #000000;
      color: #fff;
      border: none;
      padding: 14px;
      font-size: 1rem;
      border-radius: 10px;
      cursor: pointer;
      transition: 0.3s;
    }

    button:hover {
      background-color: #fb7e3b;
    }

    .contact-right {
      flex: 1 1 500px;
      min-height: 500px;
      border-radius: 15px;
      overflow: hidden;
      box-shadow: 0 15px 35px rgba(0, 0, 0, 0.1);
    }

    .contact-right iframe {
      width: 100%;
      height: 100%;
      border: 0;
    }

    @media (max-width: 900px) {
      .modern-container {
        flex-direction: column;
      }

      .form-row {
        flex-direction: column;
      }
    }
  </style>


  <%- include('partials/footer') %>
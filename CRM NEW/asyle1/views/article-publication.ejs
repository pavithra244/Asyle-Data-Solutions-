}

@keyframes rotateShape {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
}


.about-us::before,
.about-us::after,
.about-us .paper-layer {
    content: '';
    position: absolute;
    border-radius: 10px;
    box-shadow: 0 30px 70px rgba(0,0,0,0.12);
    background-image: linear-gradient(#e5e7eb 1px, transparent 1px);
    background-size: 100% 28px;
    transform-origin: center;
    animation: floatPaper 12s ease-in-out infinite, swayPaper 6s ease-in-out infinite alternate;
}

.about-us::before {
    width: 260px;
    height: 340px;
    top: 10%;
    left: 5%;
    transform: rotate(-8deg);
    --r: -8deg;
}

.about-us::after {
    width: 240px;
    height: 320px;
    bottom: 12%;
    right: 8%;
    transform: rotate(6deg);
    --r: 6deg;
    animation-delay: 6s;
}

.about-us .paper-layer:nth-child(1) {
    width: 200px;
    height: 280px;
    top: 20%;
    right: 25%;
    transform: rotate(12deg);
    --r: 12deg;
    animation-delay: 2s;
}

.about-us .paper-layer:nth-child(2) {
    width: 180px;
    height: 240px;
    bottom: 25%;
    left: 20%;
    transform: rotate(-10deg);
    --r: -10deg;
    animation-delay: 4s;
}

@keyframes floatPaper {
    0%   { transform: translateY(0) rotate(var(--r)); }
    25%  { transform: translateY(-18px) rotate(calc(var(--r)+3deg)); }
    50%  { transform: translateY(-28px) rotate(calc(var(--r)-2deg)); }
    75%  { transform: translateY(-15px) rotate(calc(var(--r)+1deg)); }
    100% { transform: translateY(0) rotate(var(--r)); }
}

@keyframes swayPaper {
    0%,100% { transform: rotate(var(--r)); }
    50% { transform: rotate(calc(var(--r)+6deg)); }
}


.about-us .container {
    position: relative;
    z-index: 2;
}

.about-us .row {
    position: relative;
}

.about-us .row::before {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50%;
    width: 2px;
    background: linear-gradient(to bottom, transparent, rgba(13,110,253,0.3), transparent);
}

@keyframes fadeSlide {
    0% { opacity: 0; transform: translateY(25px); }
    100% { opacity: 1; transform: translateY(0); }
}

.about-us .btn-primary {
    background: #fd650d;
    border: none;
    padding: 16px 30px;
    font-size: 16px;
    font-weight: 600;
    border-radius: 40px;
    position: relative;
    overflow: hidden;
    transition: 0.4s ease;
}

.about-us .btn-primary::after {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: rgba(255,255,255,0.25);
    transition: 0.5s ease;
}

.about-us .btn-primary:hover::after {
    left: 100%;
}

.about-us .btn-primary:hover {
    transform: translateY(-5px) scale(1.03);
    box-shadow: 0 12px 30px rgba(0,0,0,0.25);
}


.about-us-image {
    position: relative;
    padding: 32px;
    border-radius: 12px;
    animation: riseIn 1.2s ease forwards, floatManuscript 6s ease-in-out infinite alternate;
    overflow: hidden;
}

.about-us-image::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    z-index: 1;
    animation: glowPulse 3s ease-in-out infinite alternate;
}

.about-us-image img {
    border-radius: 8px;
    position: relative;
    z-index: 2;
}

@keyframes glowPulse {
    0%, 100% { opacity: 0.3; }
    50% { opacity: 0.6; }
}

@keyframes riseIn {
    from { opacity: 0; transform: translateY(40px); }
    to { opacity: 1; transform: translateY(0); }
}

@keyframes floatManuscript {
    0%, 100% { transform: translateY(0) rotate(-1deg); }
    50% { transform: translateY(-18px) rotate(2deg); }
}

@keyframes stampBounce {
    0% { transform: rotate(-14deg) scale(0); opacity: 0; }
    60% { transform: rotate(-14deg) scale(1.2); opacity: 1; }
    100% { transform: rotate(-14deg) scale(1); }
}



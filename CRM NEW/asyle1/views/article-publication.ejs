    position: absolute;
    font-size: 34px;
    opacity: 0.35;
    animation: floatIcon 10s ease-in-out infinite;
}

.icon.doc { top: 12%; left: 8%; animation-delay: 0s; }
.icon.pen { top: 30%; right: 12%; animation-delay: 1.5s; }
.icon.book { bottom: 18%; left: 15%; animation-delay: 3s; }
.icon.review { top: 55%; right: 20%; animation-delay: 4.5s; }
.icon.star { bottom: 25%; right: 10%; animation-delay: 6s; }

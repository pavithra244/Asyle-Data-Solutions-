    box-shadow: 0 20px 40px rgba(0,0,0,0.24);
}

.workflow-step:nth-child(1) .step-content { transform: rotateY(-24deg); }
.workflow-step:nth-child(2) .step-content { transform: rotateY(-12deg); }
.workflow-step:nth-child(3) .step-content { transform: rotateY(0deg); }
.workflow-step:nth-child(4) .step-content { transform: rotateY(12deg); }
.workflow-step:nth-child(5) .step-content { transform: rotateY(24deg); }

.workflow-step:nth-child(1) .step-circle { transform: rotateY(-24deg); }
.workflow-step:nth-child(2) .step-circle { transform: rotateY(-12deg); }
.workflow-step:nth-child(3) .step-circle { transform: rotateY(0deg); }
.workflow-step:nth-child(4) .step-circle { transform: rotateY(12deg); }
.workflow-step:nth-child(5) .step-circle { transform: rotateY(24deg); }

@keyframes floatStep {
    0%, 100% { transform: translateY(0) rotateY(var(--rotate, 0deg)); }
    25% { transform: translateY(-6px) rotateY(var(--rotate, 0deg)); }
    50% { transform: translateY(-12px) rotateY(var(--rotate, 0deg)); }
    75% { transform: translateY(-6px) rotateY(var(--rotate, 0deg)); }
}

.workflow-step {
    animation: floatStep 6s ease-in-out infinite;
}

.workflow-step:nth-child(1) { --rotate: -24deg; }
.workflow-step:nth-child(2) { --rotate: -12deg; }
.workflow-step:nth-child(3) { --rotate: 0deg; }
.workflow-step:nth-child(4) { --rotate: 12deg; }
.workflow-step:nth-child(5) { --rotate: 24deg; }

@media (max-width: 992px) {
    .workflow-timeline {
        flex-direction: column;
        align-items: center;
        gap: 70px;
    }
    .workflow-step .step-content,
    .workflow-step .step-circle {
        transform: rotateY(0deg) !important;
    }
    .workflow-timeline::before { display: none; }
    .workflow-step::after { display: none; }
}

@media (max-width: 576px) {
    .step-circle { width: 72px; height: 72px; font-size: 19px; }
    .step-content { padding: 20px 16px; border-radius: 16px; }
    .section-header h2 { font-size: 34px; }
}


    transform-style: preserve-3d;
    transition: transform 0.5s ease, filter 0.4s ease;
    z-index: 2;
    cursor: pointer;
    position: relative;
}

.workflow-step:last-child::after {
    display: none;
}

.step-circle {
    width: 90px;
    height: 90px;
    margin: 0 auto 24px auto;
    border-radius: 50%;
    background: linear-gradient(135deg, #ffffff, #ffffff);

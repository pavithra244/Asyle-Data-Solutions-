<style>
    .asyle-footer {
        background: linear-gradient(135deg, #fdfbfb, #ebedee);
        padding: 85px 20px 35px;
        font-family: 'Poppins', sans-serif;
        color: #2d2d2d;
        position: relative;
        overflow: hidden;
    }

    .asyle-footer::before,
    .asyle-footer::after {
        content: '';
        position: absolute;
        border-radius: 50%;
        filter: blur(80px);
        opacity: 0.5;
        z-index: 0;
    }

    .asyle-footer .triangle {
        position: absolute;
        width: 40px;
        height: 40px;
        background: #a5b4fc;
        clip-path: polygon(50% 0%, 0% 100%, 100% 100%);
        opacity: 0.2;
        animation: floatTriangle 8s ease-in-out infinite;
        z-index: 0;
    }

    .asyle-footer .triangle:nth-child(2) {
        background: #facc15;
        width: 30px;
        height: 30px;
        left: 60%;
        top: 10%;
        animation-duration: 10s;
    }

    @keyframes floatTriangle {

        0%,
        100% {
            transform: translateY(0) rotate(0deg);
        }

        50% {
            transform: translateY(-20px) rotate(180deg);
        }
    }

    .asyle-footer * {
        position: relative;
        z-index: 1;
    }

    .footer-about h2 {
        font-size: 27px;
        font-weight: 700;
        margin-bottom: 14px;
        color: #002559;
    }

    .footer-about p {
        font-size: 15px;
        line-height: 1.9;
        color: #4b5563;
    }

    .footer-social {
        margin-top: 22px;
    }

    .footer-social a {
        display: inline-flex;
        width: 44px;
        height: 44px;
        align-items: center;
        justify-content: center;
        border-radius: 14px;
        color: #0509d4;
        margin-right: 10px;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.08);
        transition: all 0.3s ease;
    }

    .footer-social a:hover {
        color: #017883;
        transform: translateY(-6px);
    }

    .footer-block h4,
    .footer-newsletter h4 {
        font-size: 20px;
        margin-bottom: 16px;
        color: #002559;
        font-weight: 600;
    }

    .footer-block ul {
        list-style: none;
        padding: 0;
    }

    .footer-block ul li {
        margin-bottom: 11px;
    }

    .footer-block ul li a {
        font-size: 14px;
        font-weight: 500;
        color: #031f45;
        transition: all 0.25s ease;
    }

    .footer-block ul li a:hover {
        color: #0f1195;
    }

    .footer-newsletter p {
        font-size: 14px;
        color: #4b5563;
        margin-bottom: 16px;
        line-height: 1.7;
    }

    .footer-newsletter input {
        width: 100%;
        padding: 12px 4px;
        border: none;
        border-bottom: 2px solid #d1d5db;
        background: transparent;
        font-size: 14px;
        color: #111827;
        transition: all 0.3s ease;
    }

    .footer-newsletter input::placeholder {
        color: #9ca3af;
    }

    .footer-newsletter input:focus {
        outline: none;
        border-bottom-color: #1f2937;
    }

    .footer-newsletter button {
        width: 100%;
        margin-top: 14px;
        padding: 11px;
        border: 2px solid #1f2937;
        background: transparent;
        color: #1f2937;
        font-size: 13.5px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .footer-newsletter button:hover {
        background: #1f2937;
        color: #ffffff;
    }

    .footer-newsletter button:active {
        transform: scale(0.98);
    }

    .footer-bottom {
        margin-top: 45px;
        padding-top: 20px;
        border-top: 1px solid #e5e7eb;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .footer-policy a {
        margin-right: 16px;
        font-size: 13.5px;
        font-weight: 450;
        color: #020136;
    }

    .footer-policy a:hover {
        color: #6366f1;
    }

    .footer-bottom p {
        font-size: 13.5px;
        font-weight: 450;
        color: #020136;
    }

    @media(max-width:991px) {
        .footer-bottom {
            flex-direction: column;
            gap: 12px;
            text-align: center;
        }
    }
</style>

<script src="/js/jquery-3.7.1.min.js"></script>

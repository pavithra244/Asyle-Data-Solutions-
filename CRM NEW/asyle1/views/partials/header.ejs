    <script>
        // Auth Modal Logic
        const overlay = document.getElementById('authModalOverlay');
        const modalContent = document.getElementById('authModalContent');
        const closeBtn = document.getElementById('authModalClose');

        function openAuthModal(type) {
            const isLogin = type === 'login';
            modalContent.innerHTML = `
                <h2>${isLogin ? 'Welcome Back' : 'Create Account'}</h2>
                <p class="subtitle">${isLogin ? 'Login to your account to continue' : 'Join Asyle Data Solutions today'}</p>
                <div id="authError" style="color:#ef4444; background:rgba(239,68,68,0.1); padding:10px; border-radius:8px; margin-bottom:16px; font-size:0.85rem; display:none; text-align:center; border:1px solid rgba(239,68,68,0.2);"></div>
                <form id="authForm" onsubmit="handleAuthSubmit(event, '${isLogin ? 'login' : 'register'}')">
                    ${!isLogin ? `
                    <div class="auth-input-group">
                        <i class="fas fa-user"></i>
                        <input type="text" name="username" class="auth-input" placeholder="Username" required>
                    </div>
                    ` : ''}
                    <div class="auth-input-group">
                        <i class="fas fa-envelope"></i>
                        <input type="email" name="email" class="auth-input" placeholder="Email Address" required>
                    </div>
                    <div class="auth-input-group">
                        <i class="fas fa-lock"></i>
                        <input type="password" name="password" class="auth-input" placeholder="Password" required minlength="6">
                    </div>
                    <button type="submit" class="auth-btn-primary" id="authBtn">${isLogin ? 'Login' : 'Register'}</button>
                </form>
                <div class="auth-footer" id="authFooter">
                    ${isLogin ? `Don't have an account? <a href="#" onclick="openAuthModal('register'); return false;">Register</a>`
                    : `Already have an account? <a href="#" onclick="openAuthModal('login'); return false;">Login</a>`}
                </div>
            `;
            overlay.classList.add('show');
        }

        async function handleAuthSubmit(e, type) {
            e.preventDefault();
            const form = e.target;
            const btn = document.getElementById('authBtn');
            const errorDiv = document.getElementById('authError');
            const card = document.getElementById('authModalCard');

            const formData = new FormData(form);
            const data = Object.fromEntries(formData.entries());

            card.classList.add('auth-loading');
            errorDiv.style.display = 'none';

            try {
                // Since our current routes use standard form POST and redirect, 
                // we need to handle them differently for AJAX.
                // However, let's assume the server returns JSON for AJAX requests 
                // or we can detect the redirect.
                // For now, let's keep it simple: if redirect occurs, it will be handled by the browser 
                // but fetch followed the redirect. 
                // To be safe, let's just use standard submission but maybe we can make it look nicer.
                // Actually, the request was "make it pop up".

                const response = await fetch('/' + type, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });

                if (response.redirected) {
                    window.location.href = response.url;
                    return;
                }

                // If not redirected, it's likely an error (rendering the login page again)
                // In our current index.js, POST /login renders 'login' with error if it fails.
                // We'd need to modify index.js to support JSON responses for errors.
                // Let's modify index.js slightly to support AJAX.
                const text = await response.text();
                if (text.includes('id="errorPopup"')) {
                    // Extract error from rendered page placeholder
                    const match = text.match(/<p>(.*?)<\/p>/);
                    errorDiv.textContent = match ? match[1] : 'Authentication failed';
                    errorDiv.style.display = 'block';
                } else {
                    // Try to parse as JSON if we can
                    try {
                        const json = JSON.parse(text);
                        if (json.error) {
                            errorDiv.textContent = json.error;
                            errorDiv.style.display = 'block';
                        }
                    } catch (e) {
                        // Fallback - maybe it worked but didn't redirect?
                        location.reload();
                    }
                }
            } catch (err) {
                errorDiv.textContent = 'Connection error. Please try again.';
                errorDiv.style.display = 'block';
            } finally {
                card.classList.remove('auth-loading');
            }
        }

        const linkLogin = document.getElementById('linkLogin');
        const linkRegister = document.getElementById('linkRegister');

        if (linkLogin) linkLogin.onclick = (e) => { e.preventDefault(); openAuthModal('login'); };
        if (linkRegister) linkRegister.onclick = (e) => { e.preventDefault(); openAuthModal('register'); };

        if (closeBtn) closeBtn.onclick = () => overlay.classList.remove('show');
        overlay.onclick = (e) => { if (e.target === overlay) overlay.classList.remove('show'); };
    </script>
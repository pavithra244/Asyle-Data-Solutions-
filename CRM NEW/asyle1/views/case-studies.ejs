<%- include('partials/header') %>

<div class="page-header parallaxie" style="background-image: url('images/slide.png'); background-size: cover; background-position: center; background-attachment: fixed;">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-12">
                <div class="page-header-box">
                    <h1 class="wow fadeInUp" data-cursor="-opaque">Case Studies</h1>
                    <nav class="wow fadeInUp" data-wow-delay="0.2s">
                        <ol class="breadcrumb">
                            <li class="breadcrumb-item"><a href="./">home</a></li>
                            <li class="breadcrumb-item active" aria-current="page">Case studies</li>
                        </ol>
                    </nav>
                </div>
            </div>
        </div>
    </div>
</div>

<section class="case-studies-modern">
  <div class="container">

    <div class="cs-header text-center">
      <h2>Our Case Studies & Expertise</h2>
      <p>Click on any topic to explore our detailed support and results</p>
      <div class="cs-underline"></div>
    </div>

    <div class="cs-wrapper">

      <ul class="cs-list">
        <li data-detail="detail1"><span class="cs-icon">📘</span> PhD Content Writing Support</li>
        <li data-detail="detail2"><span class="cs-icon">📝</span> Article Publication – Scopus Indexed Journal</li>
        <li data-detail="detail3"><span class="cs-icon">📚</span> Book Publication</li>
        <li data-detail="detail4"><span class="cs-icon">📊</span> Data Analytics </li>
        <li data-detail="detail5"><span class="cs-icon">🧾</span> Data Collection – PhD Survey Research</li>
      </ul>

      <div class="cs-details">

        <div id="detail1" class="cs-detail active">
          <div class="cs-content">
            <img src="images/College-Tutoring.png" alt="PhD Content Writing" class="cs-image-main">
            <h4>PhD Content Writing Support</h4>
            <p>Our team assists PhD scholars with <span>structured content creation</span>, ensuring each section of the thesis meets academic standards.</p>
            <ul class="cs-checklist">
              <li>Structured literature review and critical analysis</li>
              <li>Originality and coherence ensured</li>
              <li>Citation management and plagiarism checks</li>
            </ul>
            <p>We provide guidance for formatting, visual aids, and data presentation to strengthen research impact. Support also includes iterative feedback on methodology and discussion sections.</p>
            <p>Final reviews ensure the thesis is <span>submission-ready</span> and robust for viva defense.</p>
            <div class="cs-image-gallery">
              <img src="images/5-reasons-for-iso-9001.png" alt="Graph Example">
              <img src="images/e6589a92688133f129ab1f28639b7203.png" alt="Thesis Sample">
              <img src="images/PhD-thesis-editing-services.png" alt="Editing Process">
            </div>
            <p><strong>Solution Summary:</strong> Structured approach streamlines thesis completion while maintaining high-quality research standards.</p>
          </div>
        </div>

        <div id="detail2" class="cs-detail">
          <div class="cs-content">
            <img src="images/c7454a94c0a4da36c2d09520e4a48e69.png" alt="Article Publication" class="cs-image-main">
            <h4>Article Publication – Scopus Indexed Journal</h4>
            <p>We provide full support for publishing research articles in <span>Scopus-indexed journals</span>. From journal selection to manuscript submission, we handle all stages.</p>
            <ul class="cs-checklist">
              <li>Professional editing and proofreading</li>
              <li>Abstract, methodology, results structuring</li>
              <li>Submission strategy and revision handling</li>
            </ul>
            <p>We ensure adherence to journal formatting, high-impact quality, and proper referencing. Graphical abstracts, tables, and figures are optimized for clarity.</p>
            <div class="cs-image-gallery">
              <img src="images/manuscript_editing_for_perfection.png" alt="Manuscript Edit">
              <img src="images/energieaudit.png" alt="Graphs Charts">
              <img src="images/submission.png" alt="Submission Proof">
            </div>
            <p><strong>Solution Summary:</strong> End-to-end publishing support to help researchers succeed in high-ranking journals.</p>
          </div>
        </div>

        <div id="detail3" class="cs-detail">
          <div class="cs-content">
            <img src="images/a213518cc3c96e3c0aa30525c58928bc.png" alt="Book Publication" class="cs-image-main">
            <h4>Book Publication</h4>
            <p>We assist authors in publishing <span>academic and research-oriented books</span>. Services include manuscript structuring, chapter guidance, and readability improvements.</p>
            <ul class="cs-checklist">
              <li>Chapter-wise editing and consistency checks</li>
              <li>Publisher-ready formatting and citations</li>
              <li>Promotional and summary material creation</li>
            </ul>
            <p>We also assist with ISBN acquisition, copyright registration, and indexing to maximize academic visibility.</p>
            <div class="cs-image-gallery">
              <img src="images/24f58a65714685.Y3JvcCwxNDM4LDExMjUsMzIsMA.png" alt="Chapter Editing">
              <img src="images/thumbnail-6-1024x576.png" alt="Book Layout">
              <img src="images/645320-cdd-4ca-3f1d-e180153770_23-07-20_-_book-launch.png" alt="Promotion Material">
            </div>
            <p><strong>Solution Summary:</strong> End-to-end book publishing support to ensure professional quality and academic recognition.</p>
          </div>
        </div>

        <div id="detail4" class="cs-detail">
          <div class="cs-content">
            <img src="images/analytics15.png" alt="Retail Sales Forecasting" class="cs-image-main">
            <h4>Data Analytics</h4>
            <p>We provide actionable insights for retail sales using <span>advanced analytics</span>, predictive modeling, and machine learning.</p>
            <ul class="cs-checklist">
              <li>Trend analysis and seasonal adjustments</li>
              <li>Predictive modeling and dashboard visualizations</li>
              <li>Recommendations for marketing and inventory optimization</li>
            </ul>
            <div class="cs-image-gallery">
              <img src="images/The-Importance-Of-Trend-Analysis.png" alt="Trend Analysis">
              <img src="images/b1978f626a76d70a64f792d567562fdc.png" alt="Predictive Modeling">
              <img src="images/two-businesspeople-accountant-team-analyzing-600nw-2443676383.png" alt="Dashboard">
            </div>
            <p><strong>Solution Summary:</strong> Data-driven forecasts guiding strategic business decisions.</p>
          </div>
        </div>

        <div id="detail5" class="cs-detail">
          <div class="cs-content">
            <img src="images/1200x627_Data Collection_ Definition and Methods-Metadata.png" alt="PhD Survey Research" class="cs-image-main">
            <h4>Data Collection – PhD Survey Research</h4>
            <p>End-to-end support for <span>survey research</span> including questionnaire design, pilot testing, and ethical compliance.</p>
            <ul class="cs-checklist">
              <li>Online/offline survey administration</li>
              <li>Data validation and preliminary analysis</li>
              <li>Visualization and reporting</li>
            </ul>
            <div class="cs-image-gallery">
              <img src="images/istockphoto-1220106610-612x612.png" alt="Questionnaire">
              <img src="images/GettyImages-1345144783.png" alt="Survey Data">
              <img src="images/reporting.png" alt="Reporting">
            </div>
            <p><strong>Solution Summary:</strong> Comprehensive survey support ensuring quality and reliability of collected data.</p>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>

<style>

.case-studies-modern {
  background: #ffffff;
  padding: 120px 20px;
  font-family: 'Playfair Display', serif;
  color: #111;
}

.cs-header h2 {
  font-size: 3.2rem;
  font-weight: 700;
  letter-spacing: -0.8px;
  text-align: center;
}

.cs-header p {
  font-family: 'Inter', sans-serif;
  font-size: 1.05rem;
  color: #555;
  margin-top: 14px;
  text-align: center;
}

.cs-wrapper {
  display: flex;
  flex-wrap: wrap;
  gap: 60px;
  margin-top: 60px;
}

.cs-list {
  flex: 1 1 250px;
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.cs-list li {
  background: #fff;
  border: 2px solid #111;
  border-radius: 12px;
  padding: 16px 22px;
  font-family: 'Inter', sans-serif;
  font-size: 1rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s ease;
}

.cs-list li:hover,
.cs-list li.active {
  background: #111;
  color: #fff;
  transform: translateX(5px);
}

.cs-list li::before {
  content: none;
}

.cs-details {
  flex: 3 1 600px;
  display: flex;
  flex-direction: column;
  gap: 40px;
}

.cs-detail {
  display: none;
}

.cs-detail.active {
  display: block;
  animation: boxFade 0.5s ease;
}

@keyframes boxFade {
  from {
    opacity: 0;
    transform: translateY(15px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.cs-content {
  background: #ffffff;
  padding: 45px;
  border-radius: 16px;
  box-shadow: 0 20px 60px rgba(0,0,0,0.08);
  border: 1px solid #d1d5db;
}

.cs-image-main {
  width: 100%;
  height: 300px;
  object-fit: cover;
  margin-bottom: 25px;
  border-radius: 12px;
}

.cs-content h4 {
  font-size: 2rem;
  font-weight: 700;
  margin-bottom: 14px;
}

.cs-content p {
  font-size: 1.05rem;
  line-height: 1.8;
  margin-bottom: 14px;
}

.cs-content span {
  background: linear-gradient(transparent 60%, #fde68a 0%);
  padding: 2px 4px;
  border-radius: 4px;
}

.cs-checklist {
  margin: 20px 0;
  padding-left: 0;
  list-style: none;
}

.cs-checklist li {
  font-family: 'Inter', sans-serif;
  margin-bottom: 12px;
  padding-left: 28px;
  position: relative;
}

.cs-checklist li::before {
  content: "✔";
  position: absolute;
  left: 0;
  color: #16a34a;
  font-size: 1rem;
}

.cs-image-gallery {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
  gap: 16px;
  margin: 20px 0;
}

.cs-image-gallery img {
  width: 100%;
  height: 140px;
  object-fit: cover;
  border-radius: 10px;
  transition: transform 0.25s ease;
}

.cs-image-gallery img:hover {
  transform: scale(1.05);
}

.cs-content strong {
  display: block;
  font-family: 'Inter', sans-serif;
  margin-top: 30px;
  font-size: 1.05rem;
  border-top: 2px solid #111;
  padding-top: 18px;
}

@media (max-width: 1200px) {
  .cs-wrapper {
    flex-direction: column;
  }

  .cs-list {
    flex-direction: row;
    flex-wrap: wrap;
    gap: 12px;
    border-left: none;
    border-bottom: none;
  }

  .cs-list li {
    flex: 1 1 45%;
    text-align: center;
  }

  .cs-details {
    flex: 1 1 100%;
  }
}

@media (max-width: 768px) {
  .cs-header h2 {
    font-size: 2.4rem;
  }

  .cs-content {
    padding: 30px;
  }

  .cs-image-main {
    height: 220px;
  }

  .cs-content h4 {
    font-size: 1.7rem;
  }

  .cs-content p,
  .cs-checklist li,
  .cs-content strong {
    font-size: 0.95rem;
  }

  .cs-image-gallery {
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .cs-image-gallery img {
    height: 130px;
  }
}

@media (max-width: 480px) {
  .cs-header h2 {
    font-size: 1.9rem;
  }

  .cs-header p {
    font-size: 0.9rem;
  }

  .cs-content {
    padding: 20px;
  }

  .cs-content h4 {
    font-size: 1.4rem;
  }

  .cs-image-main {
    height: 180px;
  }

  .cs-image-gallery {
    grid-template-columns: 1fr;
    gap: 10px;
  }

  .cs-image-gallery img {
    height: 160px;
  }
}

</style>

<script>
const caseItems = document.querySelectorAll('.cs-list li');
const caseDetails = document.querySelectorAll('.cs-detail');

caseItems.forEach(item => {
  item.addEventListener('click', () => {
    caseItems.forEach(i => i.classList.remove('active'));
    caseDetails.forEach(d => d.classList.remove('active'));
    item.classList.add('active');
    document.getElementById(item.dataset.detail).classList.add('active');
  });
});
</script>



<%- include('partials/footer') %>
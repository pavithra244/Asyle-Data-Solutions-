<script>
    const caseItems = document.querySelectorAll('.case-item');
const caseContents = document.querySelectorAll('.case-content');

caseItems.forEach(item => {
  item.addEventListener('click', () => {
    caseItems.forEach(i => i.classList.remove('active'));
    caseContents.forEach(c => c.classList.remove('active'));

    item.classList.add('active');
    document.getElementById(item.dataset.case).classList.add('active');
  });
});

</script>
<style>


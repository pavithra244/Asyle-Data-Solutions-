  border-left: 6px solid #000000;
  cursor: pointer;
  font-weight: 600;
  color: #1e293b;
  transition: all 0.4s ease;
  box-shadow: 0 10px 25px rgba(0,0,0,0.08);
}

.case-item:hover,
.case-item.active {

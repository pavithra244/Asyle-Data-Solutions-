<style>

.data-collection {
    background: #ffffff;
    position: relative;
    padding: 3rem 0;
    overflow: hidden;
}

.data-collection::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(rgba(37,99,235,0.08) 1px, transparent 1px),
      linear-gradient(transparent 95%, rgba(37,99,235,0.06));
    background-size: 22px 22px, 100% 6px;
    opacity: 0.45;
}

.collection-collage.four-img {
    position: relative;
    width: 100%;
    height: 420px;
    z-index: 2;
    perspective: 1000px;
}

.collection-collage .collage-img {
    position: absolute;
    object-fit: cover;
    clip-path: polygon(
        25% 5%, 75% 5%, 
        100% 50%, 75% 95%, 
        25% 95%, 0% 50%
    );
    filter: brightness(0.95);
    box-shadow:
      0 18px 40px rgba(0,0,0,0.22),
      0 0 0 1px rgba(37,99,235,0.15);
    transition: transform 0.7s ease, filter 0.4s ease, box-shadow 0.4s ease;
    z-index: 3;
    animation: floatImg 6s ease-in-out infinite;
    transform-style: preserve-3d;
}

.collection-collage .collage-img:hover {
    transform: scale(1.15) translateZ(40px);
    filter: brightness(1.15) contrast(1.05);
    box-shadow:
      0 28px 60px rgba(0,0,0,0.35),
      0 0 40px rgba(37,99,235,0.35);
    z-index: 12;
}

.collection-collage .collage-img::before {
    content: "";
    position: absolute;
    inset: -14px;
    border-radius: 50%;
    background: conic-gradient(
      from 0deg,
      rgba(37,99,235,0.0),
      rgba(37,99,235,0.45),
      rgba(16,185,129,0.35),
      rgba(37,99,235,0.0)
    );
    filter: blur(10px);
    opacity: 0.7;
    animation: spinGlow 10s linear infinite;
    z-index: -1;
}

.collection-collage .collage-img::after {
    content: "";
    position: absolute;
    inset: -10px;
    border-radius: 50%;
    border: 2px solid rgba(37,99,235,0.4);
    animation: pulseRing 3s ease-out infinite;
}

.img-1 { width: 190px; height: 190px; top: -80px; left: 120px; animation-delay: 0s; }
.img-2 { width: 200px; height: 200px; top: 250px; right: 110px; animation-delay: 1s; }
.img-3 { width: 250px; height: 250px; top: 120px; left: 80px;  animation-delay: 2s; }
.img-4 { width: 250px; height: 250px; top: -10px; right: 80px; animation-delay: 3s; }

.collection-collage::before,
.collection-collage::after {
    content: "";
    position: absolute;
    border-radius: 50%;
    border: 2px dashed rgba(37,99,235,0.35);
    animation: rotateFlow 18s linear infinite;
}

.collection-collage::before { width: 380px; height: 380px; top: 10px; left: 20px; }
.collection-collage::after  { width: 280px; height: 280px; top: 100px; right: 30px; animation-direction: reverse; }

.collection-collage .connector {
    position: absolute;
    width: 160px;
    height: 1px;
    background: repeating-linear-gradient(
      to right,
      rgba(37,99,235,0.6) 0 6px,
      transparent 6px 12px
    );
    animation: moveDots 2.5s linear infinite;
    opacity: 0.6;
}

.connector.c1 { top: 90px; left: 260px; }
.connector.c2 { top: 220px; left: 180px; transform: rotate(20deg); }
.connector.c3 { top: 180px; right: 260px; transform: rotate(-20deg); }

.flow-arrow { position: absolute; width: 18px; height: 18px; border-right: 3px solid #2563eb; border-bottom: 3px solid #2563eb; transform: rotate(45deg); animation: arrowMove 3s ease-in-out infinite; opacity: 0.75; }
.arrow-1 { top: 70px; left: 220px; }
.arrow-2 { top: 210px; right: 230px; animation-delay: 1s; }
.arrow-3 { bottom: 90px; left: 190px; animation-delay: 2s; }

.collection-collage .scan-line {
    position: absolute; inset: 0;
    background: linear-gradient(to bottom, transparent, rgba(37,99,235,0.15), transparent);
    height: 6px;
    animation: scan 4s linear infinite;
    pointer-events: none;
}

.collection-collage .micro-label {
    position: absolute;
    padding: 4px 10px;
    font-size: 11px;
    background: rgba(37,99,235,0.9);
    color: #fff;
    border-radius: 20px;
    animation: labelFloat 4s ease-in-out infinite;
    opacity: 0.85;
}

.micro-label.l1 { top: 40px; left: 140px; }
.micro-label.l2 { top: 300px; right: 140px; animation-delay: 1.5s; }

@keyframes floatImg { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-14px); } }
@keyframes rotateFlow { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
@keyframes pulseRing { 0% { opacity: 0.6; transform: scale(1); } 70% { opacity: 0; transform: scale(1.3); } 100% { opacity: 0; } }
@keyframes spinGlow { to { transform: rotate(360deg); } }
@keyframes arrowMove { 0% { transform: translateY(0) rotate(45deg); opacity: 0.4; } 50% { transform: translateY(-10px) rotate(45deg); opacity: 0.95; } 100% { transform: translateY(0) rotate(45deg); opacity: 0.4; } }
@keyframes moveDots { from { background-position-x: 0; } to { background-position-x: 24px; } }
@keyframes scan { from { transform: translateY(-100%); } to { transform: translateY(420px); } }
@keyframes labelFloat { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-8px); } }

</style>

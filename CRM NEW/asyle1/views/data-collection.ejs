.case-studies-ultra {
  padding: 80px 0;
  font-family: 'Inter', sans-serif;
  background: #ffffff;
}

.case-cards-ultra {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 30px;
  margin-top: 50px;
}

.case-card-ultra {
  position: relative;
  height: 320px;
  border-radius: 20px;
  overflow: hidden;
  box-shadow: 0 20px 40px rgba(0,0,0,0.12);
  cursor: pointer;
  transition: transform 0.4s, box-shadow 0.4s;
  background-size: cover;
  background-position: center;
}

.case-card-ultra:hover {
  transform: translateY(-10px) scale(1.03);
  box-shadow: 0 30px 60px rgba(0,0,0,0.18);
}

.case-card-ultra .light-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(255,255,255,0.55); 
  z-index: 1;
  transition: background 0.4s;
}

.case-card-ultra:hover .light-overlay {
  background: rgba(255,255,255,0.45);
}

.case-card-ultra .overlay-dark {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  color: #1a1a1a;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 25px;
  text-align: center;
  z-index: 2;
  opacity: 0;               
  transform: translateY(20px); 
  transition: opacity 0.5s ease, transform 0.5s ease;
}

.case-card-ultra:hover .overlay-dark {
  opacity: 1;
  transform: translateY(0);
}

.case-card-ultra .case-icon {
  font-size: 45px;
  margin-bottom: 15px;
}

.case-card-ultra h4 {
  font-size: 22px;
  font-weight: 600;
  margin-bottom: 12px;
}

.case-card-ultra p {
  font-size: 15px;
  line-height: 1.6;
}

.case-card-ultra .counter {
  font-weight: 700;
  font-size: 18px;
  color: #1a1a1a;
}
</style>

<script>
const counters = document.querySelectorAll('.counter');
counters.forEach(counter => {
  counter.innerText = '0';
  const updateCounter = () => {
    const target = +counter.getAttribute('data-target');
    const current = +counter.innerText;
    const increment = Math.ceil(target / 200);
    if(current < target) {
      counter.innerText = current + increment;
      setTimeout(updateCounter, 15);
    } else {
      counter.innerText = target;
    }
  };
  updateCounter();
});
</script>




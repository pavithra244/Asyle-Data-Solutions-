<%- include('partials/header') %>

<div class="page-header parallaxie" style="background-image: url('images/cover-009.png'); background-size: cover; background-position: center; background-attachment: fixed;">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-12">
                <div class="page-header-box">
                    <h1 class="wow fadeInUp" data-cursor="-opaque">Services</h1>
                    <nav class="wow fadeInUp" data-wow-delay="0.2s">
                        <ol class="breadcrumb">
                            <li class="breadcrumb-item"><a href="./">home</a></li>
                            <li class="breadcrumb-item active" aria-current="page">Services</li>
                        </ol>
                    </nav>
                </div>
            </div>
        </div>
    </div>
</div>

<section class="asyle-services py-5">
  <div class="container">

    <div class="section-title text-center mb-5">
      <h3>Our Services</h3>
      <h2>Comprehensive Research & Data Solutions</h2>
      <p>
        Asyle Data Solution delivers end-to-end academic, analytics, and corporate research
        services with precision, integrity, and innovation.
      </p>
    </div>

    <div class="row g-4">

      <div class="col-lg-4 col-md-6">
        <div class="service-card wow fadeInUp">
          <img src="images/An-Introduction-to-Research-big.png" alt="PhD Research" class="service-img" />
          <h4>PhD Research Guidance</h4>
          <p>
            Complete PhD assistance including topic selection, proposal writing,
            literature review, research gap identification, and thesis structuring.
          </p>
        </div>
      </div>

      <div class="col-lg-4 col-md-6">
        <div class="service-card wow fadeInUp" data-wow-delay="0.1s">
          <img src="images/How-to-Write-a-Problem-Statement-for-a-Dissertation-or-Thesis.png" alt="Thesis Writing" class="service-img" />
          <h4>Thesis & Dissertation Writing</h4>
          <p>
            High-quality thesis, dissertation, and synopsis writing with
            university-compliant formatting and plagiarism-free content.
          </p>
        </div>
      </div>

      <div class="col-lg-4 col-md-6">
        <div class="service-card wow fadeInUp" data-wow-delay="0.2s">
          <img src="images/Digital-Transformation.png" alt="Statistical Analysis" class="service-img" />
          <h4>Statistical Analysis</h4>
          <p>
            Advanced data analysis using SPSS, AMOS, R, Python, Excel,
            hypothesis testing, regression, ANOVA, SEM, and forecasting models.
          </p>
        </div>
      </div>

      <div class="col-lg-4 col-md-6">
        <div class="service-card wow fadeInUp" data-wow-delay="0.3s">
          <img src="images/Accounting-Service-Image450.png" alt="Data Analytics" class="service-img" />
          <h4>Data Analytics & Visualization</h4>
          <p>
            Interactive dashboards and insights using Power BI, Tableau,
            Python visualization libraries, and business intelligence tools.
          </p>
        </div>
      </div>

      <div class="col-lg-4 col-md-6">
        <div class="service-card wow fadeInUp" data-wow-delay="0.4s">
          <img src="images/logo.png" alt="Journal Publication" class="service-img" />
          <h4>Scopus & Journal Publication</h4>
          <p>
            End-to-end journal publication support including manuscript writing,
            plagiarism reduction, formatting, submission, and reviewer handling.
          </p>
        </div>
      </div>

      <div class="col-lg-4 col-md-6">
        <div class="service-card wow fadeInUp" data-wow-delay="0.5s">
          <img src="images/data-clip-art-17.png" alt="Survey Design" class="service-img" />
          <h4>Survey Design & Data Collection</h4>
          <p>
            Questionnaire framing, sampling techniques, pilot studies,
            online/offline data collection, and dataset validation.
          </p>
        </div>
      </div>

    </div>
  </div>
</section>

<style>


.asyle-services {
  background: #ffffff;
  padding: 140px 0;
  font-family: 'Poppins', sans-serif;
}

.service-card {
  position: relative;
  background: #ffffff;
  min-height: 320px;
  padding: 40px 20px 60px; 
  border-radius: 20px;
  box-shadow: 0 25px 60px rgba(0,0,0,0.12);
  overflow: hidden;
  transition: all 0.55s ease;
  text-align: center;
}

.service-card:hover {
  transform: translateY(-10px);
  box-shadow: 0 45px 90px rgba(0,0,0,0.22);
}

.service-card .service-img {
  width: 100%;
  height: auto;
  display: block;
  margin-bottom: 25px;
  border-top-left-radius: 20px;
  border-top-right-radius: 20px;
  object-fit: cover;
}

.service-card h4 {
  font-size: 22px;
  font-weight: 700;
  margin-bottom: 12px;
  color: #020617;
  transition: color 0.45s ease;
}

.service-card:hover h4 {
  color: #03007c;
}

.service-card p {
  font-size: 14px;
  line-height: 1.75;
  color: #475569;
  margin-bottom: 20px;
  transition: color 0.45s ease;
}

.service-card:hover p {
  color: #020617;
}

.service-card .read-more {
  font-size: 14px;
  font-weight: 600;
  color: #020617;
  text-decoration: none;
  display: inline-block;
  position: relative;
  padding-bottom: 6px;
  transition: color 0.4s ease;
}

.service-card .read-more::after {
  content: "";
  position: absolute;
  left: 0;
  bottom: 0;
  width: 30px;
  height: 3px;
  background: #2a2828;
  transition: width 0.4s ease;
}

.service-card:hover .read-more {
  color: #ff3b3f;
}

.service-card:hover .read-more::after {
  width: 100%;
}

@media (max-width: 992px) {
  .service-card h4 {
    font-size: 20px;
  }
  .service-card p {
    font-size: 13px;
  }
}

@media (max-width: 576px) {
  .asyle-services {
    padding: 100px 0;
  }

  .service-card h4 {
    font-size: 18px;
  }

  .service-card p {
    font-size: 12px;
  }
}
</style>


<%- include('partials/footer') %>
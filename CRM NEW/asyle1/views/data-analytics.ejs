}

.process-step:hover::before {
    transform: translateY(-16px) scale(1.05);
    box-shadow:
        0 35px 55px rgba(59,130,246,0.55),
        inset 0 -12px 20px rgba(0,0,0,0.35);
}

.process-step:hover span::after {
    content: attr(data-step);
    position: absolute;
    top: -48px;
    left: 50%;
    transform: translateX(-50%);
    background: #020617;
    color: #e0f2fe;
    font-size: 12px;
    font-weight: 700;
    padding: 6px 14px;

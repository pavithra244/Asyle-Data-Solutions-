    height: var(--h);
    display: flex;
    align-items: flex-end;
    justify-content: center;
    z-index: 2;
}

.process-step::before {
    content: "";
    position: absolute;
    bottom: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(180deg, #2563eb, #1e293b);
    clip-path: polygon(50% 0%, 100% 100%, 0% 100%);
    box-shadow:
        0 18px 32px rgba(37,99,235,0.35),
        inset 0 -10px 16px rgba(0,0,0,0.3);
    transition: 0.4s ease;
}

.process-step::after {
    content: "";
    position: absolute;
    bottom: 0;
    width: 75%;
    height: 85%;
    background: rgba(255,255,255,0.18);
    clip-path: polygon(50% 0%, 100% 100%, 0% 100%);
}

.process-step span {
    position: relative;
    writing-mode: vertical-rl;
    transform: rotate(180deg);

}

.process-workflow-chart::before {
    content: "";
    position: absolute;
    inset: 25px 25px 70px 25px;
    background-image: linear-gradient(
        to top,
        rgba(0,0,0,0.06) 1px,
        transparent 1px
    );
    background-size: 100% 60px;
    pointer-events: none;
}

.process-workflow-chart::after {
    content: "";
    position: absolute;
    left: 30px;
    right: 30px;

<style>


.why-choose-us-horizontal {
  background: #ffffff;
  font-family: 'Poppins', sans-serif;
  min-height: 100vh;
  padding: 120px 0;
}

.h-accordion {
  display: flex;
  gap: 15px;
  height: 450px;
}

.h-item {
  flex: 1;
  border-radius: 25px;
  overflow: hidden;
  cursor: pointer;
  position: relative;
  transition: all 0.6s ease;
  background: #e2e0e0;
}

.h-item.active {
  flex: 4;
}

.h-head {
  height: 100%;
  padding: 25px;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  color: #b84802;
  z-index: 3;
}

.h-head .num {
  font-size: 42px;
  font-weight: 700;
}

.h-head .txt {
  margin-top: 10px;
  writing-mode: vertical-rl;
  transform: rotate(180deg);
  letter-spacing: 2px;
}

.h-content {
  position: absolute;
  inset: 0;
  padding: 40px;

  background-size: cover;
  background-position: center;
  background-repeat: no-repeat;

  opacity: 0;
  visibility: hidden;
  transform: scale(1.05);
  transition: opacity 0.4s ease, transform 0.5s ease;
  z-index: 2;
}

.h-item.active .h-content {
  opacity: 1;
  visibility: visible;
  transform: scale(1);
}

.h-content::before {
  content: "";
  position: absolute;
  inset: 0;
  background: linear-gradient(
    90deg,
    rgba(255,255,255,0.65) 0%,
    rgba(255,255,255,0.4) 50%,
    rgba(255,255,255,0.2) 100%
  );
  z-index: 1;
}

.h-content * {
  position: relative;
  z-index: 2;
}

.h-content h4 {
  font-size: 22px;
  font-weight: 600;
  margin-bottom: 12px;
  color: #1f2937;
}

.h-content p {
  font-size: 15px;
  line-height: 1.7;
  color: #4b5563;
  max-width: 520px;
}

@media (max-width: 992px) {

  .why-choose-us-horizontal {
    padding: 70px 0;
    min-height: auto;
  }

  .h-accordion {
    flex-direction: column;
    height: auto;
  }

  .h-item {
    flex: unset;
    background: #ffffff;
    box-shadow: 0 10px 30px rgba(0,0,0,0.08);
  }

  .h-head {
    height: auto;
    flex-direction: row;
    justify-content: flex-start;
    gap: 15px;
    padding: 18px 20px;
  }

  .h-head .num {
    font-size: 26px;
  }

  .h-head .txt {
    writing-mode: horizontal-tb;
    transform: none;
    margin: 0;
    font-size: 14px;
    font-weight: 600;
  }

  .h-content {
    position: relative;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-10px);
    padding: 0 20px;
    max-height: 0;
    overflow: hidden;
    transition: all 0.4s ease;
  }

  .h-item.active .h-content {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
    padding: 20px;
    max-height: 500px;
  }

  .h-content::before {
    background: linear-gradient(
      180deg,
      rgba(255,255,255,0.9) 0%,
      rgba(255,255,255,0.65) 70%,
      rgba(255,255,255,0.4) 100%
    );
  }

  .h-content h4 {
    font-size: 18px;
  }

  .h-content p {
    font-size: 14px;
    line-height: 1.6;
  }
}

</style>
<script>
  document.querySelectorAll('.h-item').forEach(item => {
    item.addEventListener('click', () => {
      document.querySelectorAll('.h-item')
        .forEach(el => el.classList.remove('active'));
      item.classList.add('active');
    });
  });
</script>


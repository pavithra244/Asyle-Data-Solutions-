  <style>
    
    .journal-services-gap {
      margin-top: 90px;
    }

    .journal-services-layered {
      background: linear-gradient(180deg, #ffffff 0%, #ffffff 100%);
      position: relative;
      padding-top: 20px;
    }

    .journal-services-layered::before {
      content: "";
      position: absolute;
      inset: 0;
      background-image:
        radial-gradient(circle at 20% 20%, rgba(13,110,253,0.06) 0, transparent 40%),
        radial-gradient(circle at 80% 30%, rgba(32,201,151,0.06) 0, transparent 40%);
      pointer-events: none;
    }

    .layer-card {
      position: relative;
      height: 100%;
      background: linear-gradient(180deg, #ffffff 0%, #ffffff 100%);
      padding: 38px 30px 34px;
      border-radius: 16px;
      box-shadow:
        0 10px 24px rgba(0, 0, 0, 0.06),
        0 1px 0 rgba(13,110,253,0.08);
      overflow: hidden;
      transition: transform 0.35s ease, box-shadow 0.35s ease;
    }

    .layer-card::after {
      content: "";
      position: absolute;
      inset: 0;
      border-radius: inherit;
      border: 1px solid rgba(255, 255, 255, 0.12);
      pointer-events: none;
    }

    .layer-card::before {
      content: "";
      position: absolute;
      top: -45px;
      right: -45px;
      width: 140px;
      height: 140px;
      background: linear-gradient(135deg, #000000, #000000);
      transform: rotate(45deg);
      opacity: 0.12;
    }

    .layer-card:hover {
      transform: translateY(-14px);
      box-shadow:
        0 26px 60px rgba(0, 0, 0, 0.22),
        0 6px 0 rgba(0, 0, 0, 0.15);
    }

    .layer-card .icon {
      position: absolute;
      top: 20px;
      right: 22px;
      width: 56px;
      height: 56px;
      background: #ffffff;
      border-radius: 50%;
      font-size: 22px;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 6px 14px rgba(0, 0, 0, 0.12);
      transition: transform 0.35s ease, box-shadow 0.35s ease;
    }

    .layer-card h4 {
      font-size: 1.25rem;
      font-weight: 700;
      color: #000f52;
      margin-bottom: 14px;
      padding-right: 70px;
      line-height: 1.3;
    }

    .layer-card p {
      font-size: 0.96rem;
      line-height: 1.75;
      color: #5c637a;
      margin-bottom: 0;
    }

    @keyframes fadeUp {
      from {
        opacity: 0;
        transform: translateY(18px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .layer-card {
      animation: fadeUp 0.6s ease both;
    }

    .layer-card:nth-child(odd) {
      animation-delay: 0.05s;
    }
    .layer-card:nth-child(even) {
      animation-delay: 0.12s;
    }

    @media (max-width: 768px) {
      .journal-services-gap {
        margin-top: 70px;
      }

      .layer-card {
        padding: 32px 26px 30px;
      }

      .layer-card h4 {
        font-size: 1.12rem;
      }

      .layer-card .icon {
        width: 42px;
        height: 42px;
        font-size: 20px;
      }
    }

    .who-we-serve {
      padding: 80px 20px;
      background: #ffffff; 
      text-align: center;
      font-family: 'Poppins', sans-serif;
    }

    .who-we-serve h3 {
      font-size: 36px;
      font-weight: 900;
      color: #222;
      margin-bottom: 60px;
      letter-spacing: 1px;
      position: relative;
    }

    .who-we-serve ul {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 30px;
      padding: 0;
      margin: 0 auto;
      max-width: 1100px;
      list-style: none;
    }

    .who-we-serve ul li {
      background: linear-gradient(145deg, #ffffff, #ffffff);
      padding: 40px 25px;
      border-radius: 50px 10px 50px 10px; 
      position: relative;
      font-size: 18px;
      font-weight: 600;
      color: #333;
      box-shadow: 0 15px 35px rgba(0, 0, 0, 0.237);
      transition: transform 0.5s ease, box-shadow 0.5s ease, background 0.5s ease;
      flex: 1 1 220px; 
      max-width: 260px;
      min-height: 140px;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
    }

    .who-we-serve ul li::before {
      content: "★";
      color: #ff6b35;
      font-size: 28px;
      position: absolute;
      top: -15px;
      right: -15px;
    }

    .who-we-serve ul li:hover {
      transform: scale(1.08) rotate(-2deg);
      box-shadow: 0 25px 50px rgba(0, 0, 0, 0.2);
      background: linear-gradient(145deg, #ffffff, #ffffff);
      cursor: pointer;
    }

    .who-we-serve ul li p {
      margin: 0;
      line-height: 1.5;
      font-weight: 500;
      color: #444;
    }

    @media (max-width: 768px) {
      .who-we-serve ul li {
        flex: 1 1 45%;
        max-width: 45%;
      }
    }

    @media (max-width: 480px) {
      .who-we-serve ul li {
        flex: 1 1 90%;
        max-width: 90%;
        padding: 30px 20px;
        font-size: 16px;
      }
    }

    .process {
      padding: 50px 20px;
      background: #ffffff;
      font-family: 'Poppins', sans-serif;
    }

    .process h3 {
      text-align: center;
      font-size: 36px;
      font-weight: 800;
      color: #1f2937;
      letter-spacing: 1px;
      margin-bottom: 80px;
    }

    .process-steps {
      max-width: 900px;
      margin: 0 auto;
      display: flex;
      flex-direction: column;
      gap: 60px;
      position: relative;
    }

    .process-steps .step {
      position: relative;
      background: #fff;
      border-left: 6px solid #f56d0b;
      border-radius: 30px 10px 30px 10px;
      padding: 25px 30px;
      transform: rotate(-2deg);
      box-shadow: 0 12px 25px rgba(0,0,0,0.1);
      transition: all 0.4s ease;
    }

    .process-steps .step:hover {
      transform: rotate(0deg) translateY(-10px);
      box-shadow: 0 20px 50px rgba(0,0,0,0.2);
    }

    .process-steps .step span {
      position: absolute;
      top: 50%;
      left: -35px;
      transform: translateY(-50%);
      width: 60px;
      height: 60px;
      background: #f56d0b;
      color: #fff;
      font-weight: 700;
      font-size: 20px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 0 15px rgba(245,158,11,0.5), 0 5px 15px rgba(0,0,0,0.1);
      transition: all 0.3s ease;
    }

    .process-steps .step:hover span {
      transform: translateY(-50%) scale(1.3);
    }

    .process-steps .step h4 {
      margin: 0 0 10px;
      font-size: 22px;
      font-weight: 700;
      color: #1f2937;
    }

    .process-steps .step p {
      margin: 0;
      font-size: 16px;
      color: #4b5563;
      line-height: 1.6;
    }

    .process-steps .step:nth-child(even) {
      margin-left: 80px;
      transform: rotate(2deg);
    }

    .process-steps .step:nth-child(even) span {
      left: auto;
      right: -35px;
    }

    @media (max-width: 768px) {
      .process-steps {
        gap: 40px;
      }

      .process-steps .step {
        width: 90%;
        margin-left: 0 !important;
        padding: 20px 25px;
        transform: rotate(0deg);
      }

      .process-steps .step:nth-child(even) {
        margin-left: 0;
        transform: rotate(0deg);
      }

      .process-steps .step span {
        width: 50px;
        height: 50px;
        font-size: 18px;
        left: -30px;
      }

      .process-steps .step:nth-child(even) span {
        right: -30px;
      }
    }


    .benefits-wrapper {
      display: flex;
      align-items: center;
      gap: 40px;
      padding: 50px;
      background: linear-gradient(135deg, #ffffff, #ffffff);
      border-radius: 20px;
      overflow: hidden;
      position: relative;
    }

    .benefits-content {
      flex: 1;
      position: relative;
      z-index: 1;
    }

    .benefits-content h3 {
      font-size: 28px;
      font-weight: 700;
      margin-bottom: 25px;
      color: #0a2540;
      position: relative;
    }

    .benefits-content ul {
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .benefits-content ul li {
      margin-bottom: 15px;
      padding: 14px 18px 14px 45px;
      border-radius: 12px;
      font-size: 15.5px;
      color: #334155;
      box-shadow: 0 8px 20px rgba(0, 0, 0, 0.06);
      position: relative;

    }

    .benefits-content ul li:hover {
      transform: translateX(8px);
      box-shadow: 0 12px 28px rgba(0, 0, 0, 0.12);
    }

    @media (max-width: 992px) {
      .benefits-wrapper {
        flex-direction: column;
        padding: 35px 25px;
      }

      .benefits-image {
        margin-top: 30px;
      }

      .benefits-content h3 {

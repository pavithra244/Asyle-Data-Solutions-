        border-radius 0.6s ease,
        box-shadow 0.6s ease;
}

.collage-img:hover {
    border-radius: 50% 50% 40% 60% / 60% 40% 50% 50%;
    transform: scale(1.06) rotate(1deg);
    box-shadow:
        0 30px 60px rgba(0, 0, 0, 0.28);
    z-index: 10;
}

.img-one {
    width: 60%;
    top: 80px;
    left: 20%;
    z-index: 3;
}

.img-two {
    width: 32%;
    top: 0;
    left: 0;
    z-index: 2;
}

.img-three {
    width: 32%;
    top: 10px;
    right: 0;
    z-index: 4;
}

.img-four {
    width: 36%;
    bottom: 0;
    left: 12%;
    z-index: 2;
}

.img-five {
    width: 34%;
    bottom: 50px;
    right: 0;
    z-index: 3;
}

@keyframes slowFloat {
    0% {
        transform: translateY(0);
    }
    50% {
        transform: translateY(-10px);
    }
    100% {
        transform: translateY(0);
    }
}

.img-one { animation: slowFloat 6s ease-in-out infinite; }

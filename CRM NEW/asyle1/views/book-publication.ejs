.img-three { animation: slowFloat 5.5s ease-in-out infinite; }
.img-four { animation: slowFloat 6.5s ease-in-out infinite; }
.img-five { animation: slowFloat 7.5s ease-in-out infinite; }

@media (max-width: 768px) {
    .book-pub-collage {
        height: auto;
    }


    }
}

.feature-list li {
    position: relative;
    padding-left: 40px;
    margin-bottom: 14px;
    font-size: 16px;
    font-weight: 600;
    color: #333;
    line-height: 1.6;
}

.feature-list li::before {
    content: "📚";
    position: absolute;
    left: 0;
    top: 0;
    font-size: 22px;
    line-height: 1;
}

.feature-list li:hover {
    color: #702f01;
    transform: translateX(4px);
    transition: all 0.3s ease;
}


.btn-primary.btn-lg {
    position: relative;
    padding: 15px 38px;
    font-size: 16px;
    font-weight: 600;
    letter-spacing: 0.4px;
    background: #0f172a;
    color: #ffffff;
    border: none;
    border-radius: 20px;
    box-shadow: 0 16px 32px rgba(15, 23, 42, 0.35);
    transition: all 0.45s ease;
    overflow: hidden;
}

.btn-primary.btn-lg::before {
    content: "";
    position: absolute;
    top: 0;
    left: -40%;
    width: 35%;
    height: 100%;
    background: rgba(255, 255, 255, 0.12);
    transform: skewX(-18deg);
    transition: left 0.5s ease;
}

.btn-primary.btn-lg::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 50%;
    width: 0%;
    height: 3px;
    background: #38bdf8;
    transition: all 0.4s ease;
    transform: translateX(-50%);
}

.btn-primary.btn-lg:hover {
    transform: translateY(-4px);
    box-shadow: 0 22px 44px rgba(2, 132, 199, 0.35);
}

.btn-primary.btn-lg:hover::before {
    left: 110%;
}

.btn-primary.btn-lg:hover::after {
    width: 100%;
}

.btn-primary.btn-lg:active {
    transform: scale(0.96);
}

@media (max-width: 576px) {
    .btn-primary.btn-lg {
        padding: 13px 28px;
        font-size: 15px;
    }
}

.bg-icons {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
}

.bg-icon {
    position: absolute;
    font-size: 30px;
    opacity: 1;
    animation: floatIcon 9s ease-in-out infinite;
}

.icon-1 { top: 6%; left: 6%; animation-delay: 0s; }
.icon-2 { top: 18%; right: 8%; animation-delay: 1s; }
.icon-3 { top: 44%; left: 4%; animation-delay: 2s; }
.icon-4 { bottom: 20%; right: 6%; animation-delay: 3s; }
.icon-5 { bottom: 10%; left: 18%; animation-delay: 4s; }
.icon-6 { top: 64%; right: 20%; animation-delay: 2.5s; }
.icon-7 { top: 10%; left: 48%; animation-delay: 1.5s; }
.icon-8 { bottom: 35%; right: 36%; animation-delay: 3.5s; }
.icon-9 { top: 54%; left: 62%; animation-delay: 4.5s; }

@keyframes floatIcon {
    0%   { transform: translateY(0) rotate(0deg); }
    50%  { transform: translateY(-26px) rotate(10deg); }
    100% { transform: translateY(0) rotate(0deg); }
}

</style>

